<Window x:Class="AnkerGamesClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:conv="clr-namespace:AnkerGamesClient.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="AnkerGames Client"
        Height="800" Width="1280"
        MinHeight="500" MinWidth="800"
        Background="#0f0f13"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BannerPathConverter x:Key="BannerConv"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#0f0f13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaaacc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#7c6af7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a3a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="Width" Value="5"/>
        </Style>

        <!-- ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Foreground" Value="#7c6af7"/>
            <Setter Property="Background" Value="#2a2a3a"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Small button inside cards -->
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Danger small button -->
        <Style x:Key="SmallBtnDanger" TargetType="Button" BasedOn="{StaticResource SmallBtn}">
            <Setter Property="Background" Value="#3a1a1a"/>
            <Setter Property="Foreground" Value="#ff6b6b"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5a2a2a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Nav link button (Back / Fwd) — larger, clearly clickable -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="Foreground" Value="#aaaacc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#2a2a3a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            ContextMenu — fully custom template.
            WPF's default ContextMenu has SystemDropShadowChrome which renders
            a white/light strip on the left (the icon column gutter).
            We replace the entire template to get a clean dark popup.
        -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="BorderBrush" Value="#2a2a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12"
                                                  ShadowDepth="4" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            MenuItem — custom template that removes the icon column entirely.
            The default template reserves ~28 px on the left for icons.
        -->
        <ControlTemplate x:Key="MenuItemTpl" TargetType="MenuItem">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#2a2a3a"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Normal context menu item -->
        <Style x:Key="CtxItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template" Value="{StaticResource MenuItemTpl}"/>
        </Style>

        <!-- Danger context menu item -->
        <Style x:Key="CtxItemDanger" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#ff6b6b"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template" Value="{StaticResource MenuItemTpl}"/>
        </Style>

        <!-- Window control button — neutral (minimise / maximise) -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaaacc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e1e2e"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window close button — red on hover -->
        <Style x:Key="WinBtnClose" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c0392b"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--
            Custom title bar (36 px, matches WindowChrome.CaptionHeight).
            WindowChrome.IsHitTestVisibleInChrome="True" on the window buttons
            lets them receive clicks even though the whole bar is the drag region.
        -->
        <Border Grid.Row="0" Background="#0a0a12" Height="36">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title — left side, draggable -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AnkerGames"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#7c6af7"
                               VerticalAlignment="Center"
                               Margin="14,0,10,0"/>

                    <!-- Controller connected indicator — hidden until a pad is detected -->
                    <Border x:Name="ControllerStatusText"
                            Background="#1a1a2e"
                            CornerRadius="4"
                            Padding="8,2"
                            Visibility="Collapsed"
                            VerticalAlignment="Center">
                        <TextBlock Text="Controller"
                                   FontSize="10"
                                   Foreground="#7c6af7"/>
                    </Border>
                </StackPanel>

                <!-- Window control buttons — right side -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">

                    <!-- Minimise -->
                    <Button x:Name="BtnMinimise"
                            Content="&#x2013;"
                            Width="46" Height="36"
                            Click="BtnMinimise_Click"
                            Style="{StaticResource WinBtn}"
                            ToolTip="Minimise"/>

                    <!-- Maximise / Restore -->
                    <Button x:Name="BtnMaximise"
                            Content="&#x25A1;"
                            Width="46" Height="36"
                            Click="BtnMaximise_Click"
                            Style="{StaticResource WinBtn}"
                            ToolTip="Maximise"/>

                    <!-- Close -->
                    <Button x:Name="BtnClose"
                            Content="&#x2715;"
                            Width="46" Height="36"
                            Click="BtnClose_Click"
                            Style="{StaticResource WinBtnClose}"
                            ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" x:Name="MainTabs">

            <!-- ══════════════════════════════════════
                 TAB 1  Browse
            ══════════════════════════════════════ -->
            <TabItem Header="Browse">
                <Grid Background="#0f0f13">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nav bar — minimal back/fwd + read-only URL -->
                    <Border Grid.Row="0" Background="#13131c" Padding="8,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Back: small < symbol -->
                            <Button Grid.Column="0"
                                    Height="40"
                                    Content="&#x2039;"
                                    Style="{StaticResource NavBtn}"
                                    Margin="0,0,2,0"
                                    Click="BrowserBack_Click"
                                    ToolTip="Back"/>

                            <!-- Forward: small > symbol -->
                            <Button Grid.Column="1"
                                    Height="40"
                                    Content="&#x203A;"
                                    Style="{StaticResource NavBtn}"
                                    Margin="8,8,8,8"
                                    Click="BrowserForward_Click"
                                    ToolTip="Forward"/>

                            <!-- Read-only URL — click copies to clipboard -->
                            <Border Grid.Column="2"
                                    Height="40"
                                    Background="#1a1a24" CornerRadius="6"
                                    Padding="10,5" Cursor="Hand"
                                    MouseLeftButtonUp="AddressBar_Click"
                                    ToolTip="Click to copy URL">
                                <TextBlock x:Name="AddressBar"
                                           Text="https://ankergames.net"
                                           Foreground="#888899" FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- WebView2 -->
                    <wv2:WebView2 Grid.Row="1" x:Name="WebBrowser"
                                  Source="https://ankergames.net"/>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════
                 TAB 2  Library
            ══════════════════════════════════════ -->
            <TabItem Header="Library">
                <Grid Background="#0f0f13">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: title + search bar -->
                    <Border Grid.Row="0" Padding="20,14,20,10" Background="#0f0f13">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Your Library"
                                       FontSize="20" FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <!-- Search bar — chunk-based live filter -->
                            <Border Grid.Column="2"
                                    Background="#1a1a24"
                                    CornerRadius="8"
                                    Padding="10,0"
                                    Width="260"
                                    Height="34"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Search icon label -->
                                    <TextBlock Grid.Column="0"
                                               Text="Search"
                                               FontSize="11"
                                               Foreground="#555577"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                    <!-- Input -->
                                    <TextBox Grid.Column="1"
                                             x:Name="LibrarySearchBox"
                                             Text="{Binding LibraryViewModel.SearchQuery,
                                                 UpdateSourceTrigger=PropertyChanged,
                                                 Mode=TwoWay}"
                                             Background="Transparent"
                                             Foreground="White"
                                             CaretBrush="White"
                                             BorderThickness="0"
                                             FontSize="12"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <!-- Placeholder -->
                                                                <TextBlock
                                                                    Text="Search games..."
                                                                    Foreground="#444466"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    IsHitTestVisible="False">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <ScrollViewer x:Name="PART_ContentHost"
                                                                              VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Clear button — only visible when text is present -->
                                    <Button Grid.Column="2"
                                            Content="x"
                                            FontSize="10"
                                            Foreground="#555577"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="4,0"
                                            Click="ClearSearch_Click"
                                            VerticalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LibraryViewModel.SearchQuery}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LibraryViewModel.SearchQuery}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <!-- Show when query is non-empty -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding LibraryViewModel.SearchQuery}" Value=""/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="20,0,20,20"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock x:Name="EmptyLibraryText"
                                       Text="No games installed yet. Browse and download a game to get started."
                                       Foreground="#555577" FontSize="13"
                                       TextWrapping="Wrap" Margin="0,24,0,0"
                                       Visibility="Collapsed"/>

                            <ItemsControl x:Name="GamesList"
                                          ItemsSource="{Binding LibraryViewModel.Games}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="240" Height="380"
                                                Margin="0,0,16,16"
                                                CornerRadius="10"
                                                ClipToBounds="True"
                                                Cursor="Hand">

                                            <!-- Right-click context menu — no icon column -->
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Play"
                                                              Command="{Binding LaunchCommand}"
                                                              Style="{StaticResource CtxItem}"/>
                                                    <Separator Background="#2a2a3a" Margin="0"/>
                                                    <MenuItem Header="Open in File Explorer"
                                                              Command="{Binding OpenFolderCommand}"
                                                              Style="{StaticResource CtxItem}"/>
                                                    <MenuItem Header="Search Online"
                                                              Command="{Binding SearchOnlineCommand}"
                                                              Style="{StaticResource CtxItem}"/>
                                                    <Separator Background="#2a2a3a" Margin="0"/>
                                                    <MenuItem Header="Remove from Library"
                                                              Command="{Binding DeleteCommand}"
                                                              Style="{StaticResource CtxItemDanger}"/>
                                                    <MenuItem Header="Uninstall (Delete Files)"
                                                              Command="{Binding UninstallCommand}"
                                                              Style="{StaticResource CtxItemDanger}"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <!-- Left-click = launch -->
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding LaunchCommand}"/>
                                            </Border.InputBindings>

                                            <Grid>
                                                <!-- Banner image 240 x 320 -->
                                                <Border Height="320" VerticalAlignment="Top"
                                                        CornerRadius="10,10,0,0"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Border Background="#1a1a2e">
                                                            <TextBlock Text="No Image"
                                                                       FontSize="13"
                                                                       Foreground="#333355"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Image Stretch="UniformToFill"
                                                               Source="{Binding BannerPath,
                                                                   Converter={StaticResource BannerConv},
                                                                   Mode=OneWay}"/>
                                                        <Border x:Name="HoverOverlay"
                                                                Background="#AA000000"
                                                                Opacity="0">
                                                            <TextBlock Text="Play"
                                                                       FontSize="28"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- Title footer -->
                                                <Border Height="60" VerticalAlignment="Bottom"
                                                        Background="#CC0d0d18">
                                                    <Border Width="120" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Border>
                                            </Grid>

                                            <!-- Purple glow on hover -->
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#7c6af7"
                                                                                      BlurRadius="20"
                                                                                      ShadowDepth="0"
                                                                                      Opacity="0.75"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="HoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="1" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="HoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="0" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════
                 TAB 3  Downloads
            ══════════════════════════════════════ -->
            <TabItem Header="Downloads">
                <Grid Background="#0f0f13">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header row: title + Clear button -->
                    <Border Grid.Row="0" Padding="20,16,20,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Downloads"
                                       FontSize="20" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Clear Finished"
                                    Command="{Binding DownloadCenterViewModel.ClearCompletedCommand}"
                                    Padding="12,6"
                                    FontSize="11"
                                    Background="#1a1a2e"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="20,0,20,20"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- Empty state -->
                            <TextBlock Text="No active downloads."
                                       Foreground="#555577" FontSize="13"
                                       Margin="0,24,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding DownloadCenterViewModel.Downloads.Count}"
                                                Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!--
                                Download cards — 240 x 380, same as library.
                                Banner area (320 px): shows placeholder while downloading,
                                  then the scraped image after extraction.
                                Hover overlay: all download details + Pause + Cancel.
                                Footer (60 px): filename + progress bar (click = pause/resume).
                            -->
                            <ItemsControl ItemsSource="{Binding DownloadCenterViewModel.Downloads}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="240" Height="380"
                                                Margin="0,0,16,16"
                                                CornerRadius="10"
                                                ClipToBounds="True"
                                                Background="#1a1a24">
                                            <Grid>

                                                <!-- Banner area 240 x 320 -->
                                                <Border Height="320" VerticalAlignment="Top"
                                                        CornerRadius="10,10,0,0"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <!-- Placeholder -->
                                                        <Border Background="#13131c">
                                                            <TextBlock
                                                                Text="{Binding Status, Mode=OneWay}"
                                                                FontSize="11"
                                                                Foreground="#333355"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Banner (populated after extraction) -->
                                                        <Image Stretch="UniformToFill"
                                                               Source="{Binding BannerPath,
                                                                   Converter={StaticResource BannerConv},
                                                                   Mode=OneWay}"/>

                                                        <!-- Hover overlay — all details -->
                                                        <Border x:Name="DlHoverOverlay"
                                                                Background="#EE0d0d18"
                                                                Opacity="0"
                                                                Padding="16">
                                                            <StackPanel VerticalAlignment="Center">

                                                                <TextBlock
                                                                    Text="{Binding FileName, Mode=OneWay}"
                                                                    FontSize="12" FontWeight="Bold"
                                                                    TextWrapping="Wrap"
                                                                    TextAlignment="Center"
                                                                    Margin="0,0,0,10"/>

                                                                <TextBlock
                                                                    Text="{Binding Status, Mode=OneWay}"
                                                                    FontSize="11"
                                                                    Foreground="#aaaacc"
                                                                    TextAlignment="Center"
                                                                    Margin="0,0,0,8"/>

                                                                <ProgressBar
                                                                    Value="{Binding Progress, Mode=OneWay}"
                                                                    Minimum="0" Maximum="100"
                                                                    Height="5"
                                                                    Margin="0,0,0,4"/>

                                                                <TextBlock FontSize="11"
                                                                           Foreground="#aaaacc"
                                                                           TextAlignment="Center"
                                                                           Margin="0,0,0,6">
                                                                    <Run Text="{Binding Progress, Mode=OneWay}"/>
                                                                    <Run Text="%"/>
                                                                </TextBlock>

                                                                <Grid Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Speed, Mode=OneWay}"
                                                                               FontSize="11"
                                                                               Foreground="#aaaacc"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               FontSize="11"
                                                                               Foreground="#aaaacc"
                                                                               TextAlignment="Right">
                                                                        <Run Text="ETA "/>
                                                                        <Run Text="{Binding Eta, Mode=OneWay}"/>
                                                                    </TextBlock>
                                                                </Grid>

                                                                <TextBlock FontSize="11"
                                                                           Foreground="#aaaacc"
                                                                           TextAlignment="Center"
                                                                           Margin="0,0,0,14">
                                                                    <Run Text="{Binding ReceivedBytesFormatted, Mode=OneWay}"/>
                                                                    <Run Text=" / "/>
                                                                    <Run Text="{Binding TotalBytesFormatted, Mode=OneWay}"/>
                                                                </TextBlock>

                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Center">
                                                                    <Button
                                                                        Content="{Binding PauseResumeLabel, Mode=OneWay}"
                                                                        Command="{Binding PauseResumeCommand}"
                                                                        IsEnabled="{Binding CanPauseResume, Mode=OneWay}"
                                                                        Style="{StaticResource SmallBtn}"
                                                                        Margin="0,0,8,0"/>
                                                                    <Button
                                                                        Content="Cancel"
                                                                        Command="{Binding CancelCommand}"
                                                                        IsEnabled="{Binding CanCancel, Mode=OneWay}"
                                                                        Style="{StaticResource SmallBtnDanger}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- Footer 60 px: filename + progress bar -->
                                                <Border Height="60" VerticalAlignment="Bottom"
                                                        Background="#CC0d0d18"
                                                        Padding="10,6">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock
                                                            Text="{Binding FileName, Mode=OneWay}"
                                                            FontSize="11" FontWeight="SemiBold"
                                                            TextTrimming="CharacterEllipsis"
                                                            Margin="0,0,0,5"/>
                                                        <ProgressBar
                                                            Value="{Binding Progress, Mode=OneWay}"
                                                            Minimum="0" Maximum="100"
                                                            Height="4"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="ProgressBar_Click"
                                                            Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- Purple glow on hover -->
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#7c6af7"
                                                                                      BlurRadius="20"
                                                                                      ShadowDepth="0"
                                                                                      Opacity="0.6"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <!-- Fade detail overlay in/out -->
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="DlHoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="1" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="DlHoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="0" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
